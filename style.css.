body {
  font-family: 'Rubik', sans-serif;
  margin: 0;
  background: #fafafa;
  color: #222;
}

/* ---------- NAV ---------- */

header {
  position: sticky;
  top: 0;
  background: white;
  border-bottom: 1px solid #ddd;
}

nav {
  max-width: 900px;
  margin: auto;
  padding: 15px;
  text-align: center;
}

nav a {
  margin: 0 15px;
  text-decoration: none;
  color: black;
  font-weight: 500;
}

nav a:hover {
  opacity: 0.6;
}

/* ---------- HERO ---------- */

.hero {
  text-align: center;
  padding: 80px 20px;
}

.hero h1 {
  font-size: 3rem;
  margin-bottom: 10px;
}

/* ---------- ABOUT ---------- */

.about {
  max-width: 900px;
  margin: auto;
  padding: 40px 20px;
}

.about-grid {
  display: grid;
  grid-template-columns: 1fr 2fr;
  gap: 30px;
  align-items: center;
}

.about img {
  width: 100%;
  border-radius: 8px;
}

/* ---------- FOOTER ---------- */

footer {
  text-align: center;
  padding: 40px;
  opacity: 0.6;
}

/* ---------- MOBILE ---------- */

@media (max-width: 700px) {
  .about-grid {
    grid-template-columns: 1fr;
  }
}
